# ---- Copy to .env and fill in. Never commit .env. ----

# OpenAI: used for structured extraction (Pass 1/2), the L2 cross-check, and the proof demo.
# Required for any real run.
OPENAI_API_KEY=

# Composio: PRIMARY search + scrape backend, and the proof-demo tool calls.
# Optional — if empty (or USE_FALLBACK=true), the free fallback backend is used for research.
COMPOSIO_API_KEY=

# Backend switch.
#   false -> try Composio first, auto-fall-back to the free pipeline on quota/limit/error (recommended)
#   true  -> force the free fallback backend (no Composio calls at all)
USE_FALLBACK=false

# Model used for extraction + cross-check. Any structured-output-capable model works.
OPENAI_MODEL=gpt-4o-mini

# Which app the proof demo drives (must be a self-serve, Composio-supported easy win).
PROOF_APP=github

# Optional: identifies the Composio end-user for connected accounts (proof demo). Any stable string.
COMPOSIO_USER_ID=composio-assignment-user
